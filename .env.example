# Runtime
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
TARGET_PLATFORM=linux/arm64

# Real LLM configuration is intentionally blank until approval gate G3.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=30

# PostgreSQL/PostGIS (local development placeholders only)
POSTGRES_DB=hennongxi
POSTGRES_USER=hennongxi
POSTGRES_PASSWORD=local-development-only
POSTGIS_PACKAGE_VERSION=3.6.4+dfsg-2.pgdg12+1
DATABASE_URL=postgresql+asyncpg://hennongxi:local-development-only@postgis:5432/hennongxi

# Redis
REDIS_URL=redis://redis:6379/0

# Local, task-scoped data and artifact locations inside containers
DATA_MANIFEST_PATH=/app/data/manifest.json
DATA_CACHE_DIR=/data/cache
ARTIFACT_ROOT=/data/outputs

# Versioned service endpoints on the private Compose network
MASTER_BASE_URL=http://master-agent:8000
DATA_AGENT_BASE_URL=http://data-agent:8001
ANALYSIS_AGENT_BASE_URL=http://analysis-agent:8002
QUALITY_AGENT_BASE_URL=http://quality-agent:8003
PUBLISHER_AGENT_BASE_URL=http://publisher-agent:8004

# Browser-visible endpoints
PUBLIC_MASTER_BASE_URL=http://localhost:8000
PUBLIC_PUBLISHER_BASE_URL=http://localhost:8004
