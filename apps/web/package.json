{
  "name": "@hennongxi/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "pnpm": ">=11.9.0 <12.0.0"
  },
  "scripts": {
    "api:generate": "openapi-typescript ../../docs/openapi.yaml --output src/api/schema.generated.ts --immutable",
    "api:check": "openapi-typescript ../../docs/openapi.yaml --output src/api/schema.generated.ts --immutable --check",
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "tsc -b && vite build",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "maplibre-gl": "5.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.7.0",
    "jsdom": "29.1.1",
    "openapi-typescript": "7.13.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.0",
    "vitest": "4.1.10"
  }
}
